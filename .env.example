# =============================================================================
# .env.example — SIGNPOST ONLY
#
# Squads are configured per instance, never from a repo-root .env:
#
#   THE REAL TEMPLATE IS  deploy/templates/squad.env.template
#
# `./squadctl new <slug>` renders it into /srv/squads/<slug>/.env (mode 0600,
# outside every git tree) and generates the per-squad secrets. Compose is then
# always driven as:
#
#   docker compose -p <slug> --env-file /srv/squads/<slug>/.env ...
#
# (squadctl wraps that for you). Do NOT copy this file to .env and expect the
# stack to boot — it exists only to document the variable groups for people
# browsing the repo. Placeholders only; never commit a real value.
# =============================================================================

# === Identity (one slug derives everything) ===
COMPOSE_PROJECT_NAME=<slug>
SQUAD_HOME=/srv/squads/<slug>

# === Port block (loopback-only; allocated by squadctl) ===
SQUAD_PORT_BASE=7800
SQUAD_DASH_PORT=7801
SQUAD_PAPERCLIP_PORT=7802
SQUAD_PLAYWRIGHT_PORT=7803

# === LLM provider ===
# Default: claude.ai OAuth (login once via the dashboard terminal; persisted in
# the <slug>_war-room-state volume). Alternatives:
# ANTHROPIC_API_KEY=
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_ACCESS_KEY_ID= / AWS_SECRET_ACCESS_KEY= / AWS_REGION=

# === Telegram (per-squad bots — N-agent pattern) ===
# Token env names are ROSTER DATA: each agent in the squad's config/agents.json
# declares its own `token_env` (convention: <AGENT_SLUG>_TELEGRAM_TOKEN). The
# captain's token lives in the squad .env; every other agent's token goes in
# $SQUAD_HOME/private/agent-tokens.env (0600, KEY=value lines, loaded by
# launch.sh at boot — file wins over env). Empty token = that agent is CLI-only.
CAPTAIN_TELEGRAM_TOKEN=
SQUAD_TELEGRAM_GROUP_ID=
OPERATOR_TELEGRAM_ID=

# === Dashboard auth (per-squad realm; generated by squadctl new) ===
WARROOM2_BASIC_AUTH_USER=<slug>
WARROOM2_BASIC_AUTH_PASS=<generated-by-squadctl>
WARROOM2_ADMIN_TOKEN=<generated-by-squadctl>

# === Paperclip (per-squad instance) ===
BETTER_AUTH_SECRET=<generated-by-squadctl>
PAPERCLIP_PUBLIC_URL=http://paperclip.<slug>.localhost:8800
PAPERCLIP_ALLOWED_HOSTNAMES=paperclip,localhost,127.0.0.1,paperclip.<slug>.localhost
PAPERCLIP_COMPANY_ID=
AZURE_OPENAI_API_KEY=

# === Project repo (fill before first real use) ===
PROJECT_REPO_URL=
PROJECT_WORKSPACE_NAME=
BITBUCKET_TOKEN=

# === Resource limits (ceilings; RAM is the VM budget — max ~3 squads/VM) ===
# WAR_ROOM_MEM=2.5g / PAPERCLIP_MEM=1.25g / WARROOM2_MEM=384m / PLAYWRIGHT_MEM=768m

# Everything else (docker-socket mode + socket-proxy opt-in, legacy openclaw
# exec target, deploy SSH, Trello, git identities, model overrides) is
# documented inline in deploy/templates/squad.env.template — read that file.
