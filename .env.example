UX_GONORTH_TELEGRAM_TOKEN=

# === Required: Telegram Group IDs ===
GONORTH_GROUP_ID=

# === Optional: Operator ===
OPERATOR_TELEGRAM_ID=

# === Paperclip ===
BETTER_AUTH_SECRET=change-me-to-a-random-string
