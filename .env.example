# =============================================================================
# .env.example — AI Agent War Room configuration
# Copy to .env and fill in required values:  cp .env.example .env
# =============================================================================

# === Required: LLM Provider ===
# Choose ONE provider — either Anthropic API key or AWS Bedrock.
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_USE_BEDROCK=1             # Set to 1 to use AWS Bedrock
# AWS_ACCESS_KEY_ID=...                 # Required if using Bedrock
# AWS_SECRET_ACCESS_KEY=...             # Required if using Bedrock
# AWS_REGION=us-east-1                  # Required if using Bedrock

# === Required: Telegram Bot Tokens ===
# Each agent runs its own Telegram bot. Create bots via @BotFather.
CAPTAIN_TELEGRAM_TOKEN=
CEO_GONORTH_TELEGRAM_TOKEN=
UX_GONORTH_TELEGRAM_TOKEN=

# === Required: Telegram Group ===
# The Telegram group/chat ID where agents collaborate.
GONORTH_GROUP_ID=

# === Optional: Operator ===
# Your personal Telegram user ID (for DM notifications from agents).
# OPERATOR_TELEGRAM_ID=

# === Optional: Model Overrides ===
# Override the Claude model used by each agent.
# CAPTAIN_MODEL=sonnet                  # default: sonnet
# CEO_MODEL=opus                        # default: opus
# UX_MODEL=sonnet                       # default: sonnet

# === ttyd Web Terminal ===
# Basic auth for the browser-based terminal. Leave blank for no auth.
# TTYD_USERNAME=admin
# TTYD_PASSWORD=change-me
# TTYD_PORT=7681                        # Host port for ttyd (default: 7681)

# === Paperclip ===
# PAPERCLIP_SOURCE=./paperclip          # Path to Paperclip source checkout
# PAPERCLIP_PORT=3100                   # Host port for Paperclip UI (default: 3100)
# PAPERCLIP_PUBLIC_URL=http://localhost:3100  # External URL for Paperclip
# OPENAI_API_KEY=                       # Optional: for Paperclip Codex adapter

# Azure OpenAI — used by Paperclip's codex_local adapter (primary as of 2026-04-18)
AZURE_OPENAI_API_KEY=
# Note: OPENAI_API_KEY is no longer required for Paperclip — keep only if you
# use direct api.openai.com for other services.

# === Project Repository ===
# The Go-North source repo. Cloned at container startup into /workspace/project.
# If the repo has ./agents/{name}/CLAUDE.md files, they override the baked-in versions.
# GONORTH_REPO_URL=https://bitbucket.org/Liran_katz/go-north-dev-agents.git

# === Bitbucket Cloud (for agent code management) ===
# Use EITHER token OR username/password (token takes precedence)
# BITBUCKET_TOKEN=your-access-token
# BITBUCKET_USERNAME=your-email@example.com
# BITBUCKET_PASSWORD=your-app-password
# BITBUCKET_URL=https://api.bitbucket.org/2.0  # default for Cloud

# === Trello (task management) ===
# Get API key at: https://trello.com/app-key
# Generate token at: https://trello.com/1/authorize?key=YOUR_KEY&scope=read,write&expiration=never&response_type=token&name=WarRoom
# TRELLO_API_KEY=your-trello-api-key
# TRELLO_API_TOKEN=your-trello-token

# === Paperclip Company ===
# PAPERCLIP_COMPANY_ID=a951bb35-24a9-412a-bbcc-629c5acae619

# === Deployment (SSH to Plesk) ===
# Path to SSH private key on the host machine. Mounted into the container.
# Generate: ssh-keygen -t ed25519 -f ./deploy_key -N ""
# Then add deploy_key.pub to Plesk: gonorthdev@34.165.203.65:~/.ssh/authorized_keys
# IMPORTANT: chown the key on the host to uid:gid 1000:1000 (matches the `node`
# user the paperclip container runs as) and keep mode 0600. Otherwise the CEO
# agent will get "Permission denied" when trying to use the key for Phase C
# deploy, even though the bind-mount itself works. Example:
#   sudo chown 1000:1000 ./deploy_key && chmod 0600 ./deploy_key
# DEPLOY_SSH_KEY_PATH=./deploy_key

# === Paperclip Agent IDs (auto-populated by setup script) ===
# These are written by scripts/setup.sh after agent registration.
# CAPTAIN_PAPERCLIP_AGENT_ID=
# CEO_GONORTH_PAPERCLIP_AGENT_ID=
# UX_GONORTH_PAPERCLIP_AGENT_ID=

# ─── War Room 2.0 (NEW — tabbed dashboard, parallel to ttyd on :7681) ───
WARROOM2_PORT=7682
WARROOM2_BASIC_AUTH_USER=
WARROOM2_BASIC_AUTH_PASS=
# Leave the basic-auth fields blank to disable auth (dev mode only — will log a WARN at startup).
