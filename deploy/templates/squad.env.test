# =============================================================================
# squad.env.test — NON-SECRET fixture for validating the compose template:
#
#   docker compose -f docker-compose.yml \
#     --env-file deploy/templates/squad.env.test -p probe config -q
#
# Every value is a deliberately fake placeholder (slug `probe`, port block
# 7900). NEVER put real tokens/secrets here — this file is tracked in a
# public repo and exists only so `compose config` resolves cleanly in CI /
# milestone acceptance checks.
# =============================================================================

COMPOSE_PROJECT_NAME=probe
SQUAD_HOME=/srv/squads/probe

SQUAD_PORT_BASE=7900
SQUAD_DASH_PORT=7901
SQUAD_PAPERCLIP_PORT=7902
SQUAD_PLAYWRIGHT_PORT=7903

CAPTAIN_TELEGRAM_TOKEN=
SQUAD_TELEGRAM_GROUP_ID=-1000000000000
OPERATOR_TELEGRAM_ID=1

WARROOM2_BASIC_AUTH_USER=probe
WARROOM2_BASIC_AUTH_PASS=not-a-real-password-test-fixture
WARROOM2_ADMIN_TOKEN=not-a-real-token-test-fixture

PAPERCLIP_DEPLOYMENT_MODE=local_trusted
BETTER_AUTH_SECRET=not-a-real-secret-test-fixture
PAPERCLIP_PUBLIC_URL=http://paperclip.probe.localhost:8800
PAPERCLIP_ALLOWED_HOSTNAMES=paperclip,localhost,127.0.0.1,paperclip.probe.localhost
PAPERCLIP_COMPANY_ID=00000000-0000-0000-0000-000000000000
PAPERCLIP_SOURCE=./paperclip
AZURE_OPENAI_API_KEY=

PROJECT_REPO_URL=https://example.invalid/probe/project.git
PROJECT_WORKSPACE_NAME=probe-app
BITBUCKET_TOKEN=

SQUAD_OPENCLAW_CONTAINER=

# Raw-socket DEFAULT (plan §7.4) — acceptance checks assert this resolves to
# a /var/run/docker.sock volume source and NO docker-proxy in the graph.
# Opt-in overrides exercised by the acceptance checks via the environment:
# WARROOM2_DOCKER_SOCK=/dev/null WARROOM2_DOCKER_HOST=tcp://docker-proxy:2375
# with --profile socket-proxy.
WARROOM2_DOCKER_SOCK=/var/run/docker.sock
SQUAD_EXEC_ALLOW_REGEX=probe-[a-z0-9-]+

WAR_ROOM_MEM=2.5g
WAR_ROOM_CPUS=2
PAPERCLIP_MEM=1.25g
PAPERCLIP_CPUS=1
WARROOM2_MEM=384m
WARROOM2_CPUS=0.5
PLAYWRIGHT_MEM=768m
PLAYWRIGHT_CPUS=1
