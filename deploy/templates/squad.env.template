# =============================================================================
# squad.env.template — per-squad environment skeleton
#
# Rendered by `squadctl new <slug>` into /srv/squads/<slug>/.env (mode 0600).
# That file lives OUTSIDE any git tree and is the single interpolation source
# for the squad's compose project:
#
#   docker compose -p <slug> --env-file /srv/squads/<slug>/.env up -d
#
# Placeholders only — NO real secrets in this template, ever (public repo).
# Replace <slug> with the squad slug (^[a-z][a-z0-9-]{1,22}$).
# NOTE: no inline comments after values — compose .env parsing would keep them.
# =============================================================================

# === Identity ===
# Everything derives from the slug: containers <slug>-<service>-1, network
# <slug>_default, volumes <slug>_<volume>.
COMPOSE_PROJECT_NAME=<slug>
SQUAD_HOME=/srv/squads/<slug>

# === Port block (loopback-only; 127.0.0.1 binds — never internet-facing) ===
# SQUAD_PORT_BASE = 7700 + 100*i (allocated by squadctl);
# dash = base+1, paperclip = base+2, playwright = base+3.
# Tenant #1 (the original squad) is grandfathered on 7682 / 3100 / 8931.
SQUAD_PORT_BASE=7800
SQUAD_DASH_PORT=7801
SQUAD_PAPERCLIP_PORT=7802
SQUAD_PLAYWRIGHT_PORT=7803

# === LLM provider (war-room agents) ===
# Default is claude.ai OAuth (persisted in the <slug>_war-room-state volume —
# log in once via the dashboard terminal). Bedrock alternative:
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# === Telegram (per-squad bots) ===
# Token env names must match `token_env` in this squad's config/agents.json.
# The captain token lives here; tokens for additional agents go in
# $SQUAD_HOME/private/agent-tokens.env (0600, KEY=value lines — loaded by
# launch.sh at boot). Empty token = that agent runs CLI-only.
CAPTAIN_TELEGRAM_TOKEN=
# Telegram group/chat ID where the squad collaborates. Can be filled later:
# edit, then `./squadctl apply <slug> war-room`.
SQUAD_TELEGRAM_GROUP_ID=
# Operator's personal Telegram user ID (DM notifications, wizard default).
OPERATOR_TELEGRAM_ID=

# === Dashboard auth (per-squad realm; generated by squadctl new) ===
WARROOM2_BASIC_AUTH_USER=<slug>
WARROOM2_BASIC_AUTH_PASS=<generated-by-squadctl>
# Token gating the admin wizard (/api/admin/wizard/*). Empty = wizard disabled.
WARROOM2_ADMIN_TOKEN=<generated-by-squadctl>

# === Paperclip (per-squad instance — independent rotation/blast radius) ===
BETTER_AUTH_SECRET=<generated-by-squadctl>
PAPERCLIP_PUBLIC_URL=http://paperclip.<slug>.localhost:8800
PAPERCLIP_ALLOWED_HOSTNAMES=paperclip,localhost,127.0.0.1,paperclip.<slug>.localhost
# Written back by scripts/setup-company.sh during squadctl's staged bring-up.
PAPERCLIP_COMPANY_ID=
# Path to the Paperclip source checkout (build context).
# PAPERCLIP_SOURCE=./paperclip
# LLM keys for Paperclip adapters (Azure is the codex_local primary).
AZURE_OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# === Project repo (FILL BEFORE FIRST REAL USE) ===
# Cloned at war-room startup into /workspace/project.
PROJECT_REPO_URL=
# Workspace dir name scripts operate on inside /workspace/project.
PROJECT_WORKSPACE_NAME=
# Bitbucket Cloud: token OR username/password (token takes precedence).
BITBUCKET_TOKEN=
# BITBUCKET_USERNAME=
# BITBUCKET_PASSWORD=
# BITBUCKET_URL=https://api.bitbucket.org/2.0

# === Legacy exec target (tenant #1 ONLY — leave empty for new squads) ===
# Extra dashboard tab that docker-execs into the out-of-project openclaw
# container (yefet). Example value: interactive-dev-team-openclaw-1
SQUAD_OPENCLAW_CONTAINER=

# === Resource limits (ceilings, not reservations — RAM is the VM budget) ===
# Defaults match the platform RAM budget; override per squad if needed
# (tenant #1 runs WAR_ROOM_MEM=3g for 3 agents + yefet). Max 3 squads per VM.
WAR_ROOM_MEM=2.5g
WAR_ROOM_CPUS=2
PAPERCLIP_MEM=1.25g
PAPERCLIP_CPUS=1
WARROOM2_MEM=384m
WARROOM2_CPUS=0.5
PLAYWRIGHT_MEM=768m
PLAYWRIGHT_CPUS=1

# === Optional extras ===
# Captain model override (other agents: config/agents.json model_env/default).
# CAPTAIN_MODEL=sonnet
# Git identity for Paperclip agent commits.
# GIT_AUTHOR_NAME=Paperclip Agent
# GIT_AUTHOR_EMAIL=agent@<slug>.localhost
# Git identity for war-room agent commits in the project clone.
# GIT_IDENTITY_NAME=War Room Agent
# GIT_IDENTITY_EMAIL=war-room@<slug>.localhost
# SSH key for Plesk deploys (host path; chown 1000:1000, mode 0600).
# DEPLOY_SSH_KEY_PATH=
# Plesk deploy target — launch.sh writes the SSH Host block only when BOTH
# host and user are set; root/url drive the Plesk deploy script.
# DEPLOY_SSH_HOST=
# DEPLOY_SSH_USER=
# DEPLOY_REMOTE_ROOT=/var/www/vhosts/<site>/httpdocs
# DEPLOY_SITE_URL=https://<site>
# Trello (task management).
# TRELLO_API_KEY=
# TRELLO_API_TOKEN=
