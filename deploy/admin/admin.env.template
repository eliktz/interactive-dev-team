# =============================================================================
# admin.env.template — platform ADMIN console environment skeleton
#
# The REAL file lives OUTSIDE git at /srv/platform-admin/.env (mode 0600,
# owner ravi:ravi — NEVER committed). Render this template there and fill the
# placeholders; it is the single interpolation source for the admin project:
#
#   docker compose -p platform-admin --env-file /srv/platform-admin/.env \
#     -f deploy/admin/docker-compose.admin.yml up -d   # NEVER --remove-orphans
#
# Placeholders only — NO real secrets in this template, ever (public repo).
# NOTE: no inline comments after values — compose .env parsing would keep them.
#
# /srv/platform-admin/ is created 0750 ravi:caddy (so caddy can traverse to read
# the caddy.snippet); .env is 0600 ravi:ravi; agents/ holds the persona seed.
# =============================================================================

# === Admin agent (platform-admin service) ===
# tmux session name — MUST equal WARROOM2_TMUX_SESSION below or the dash tab _stale's.
ADMIN_TMUX_SESSION=war-room
ADMIN_MODEL=sonnet
ADMIN_CPUS=1
# plan §11a RAM recompute (single tmux Claude session). Swapless VM — verify
# `free -m` headroom before standing up a 3rd squad alongside the admin.
ADMIN_MEM=768m
# Admin LLM: claude.ai OAuth (log in once in the tab; persisted in the
# platform-admin-state volume) OR an API key:
# ANTHROPIC_API_KEY=
TZ=UTC

# === Admin socket-proxy (admin-docker-proxy service) ===
# Host-loopback port the host-net agent reaches the proxy at (DOCKER_HOST=tcp://127.0.0.1:2380).
ADMIN_PROXY_PORT=2380
ADMIN_PROXY_CPUS=0.25
ADMIN_PROXY_MEM=64m

# === Admin dashboard (admin-warroom2 service) ===
# Loopback-only publish port for the dashboard (Caddy reverse_proxy target).
SQUAD_DASH_PORT=7900
ADMIN_WARROOM2_CPUS=0.5
ADMIN_WARROOM2_MEM=384m

# Retarget the single tab at the admin container (by container NAME).
WARROOM2_WARROOM_CONTAINER=platform-admin
# MUST equal ADMIN_TMUX_SESSION above (entrypoint SESSION) or the tab _stale's.
WARROOM2_TMUX_SESSION=war-room
# Container mount of /srv/platform-admin (holds config/agents.json + bus/ + agents/).
WARROOM2_SQUAD_HOME=/workspace/interactive-dev-team
# EMPTY -> no bus tab (a tmux-only roster has no openclaw/bus host).
WARROOM2_OPENCLAW_CONTAINER=
# Header label (else the derived raw-name slug is ugly).
WARROOM2_COMPANY_NAME=Admin
# Dashboard auth realm. Generate the pass with: openssl rand -hex 16
WARROOM2_BASIC_AUTH_USER=admin
WARROOM2_BASIC_AUTH_PASS=<openssl rand -hex 16>
# EMPTY -> disable the mount-agent wizard on the admin dash.
WARROOM2_ADMIN_TOKEN=
# Raw ro socket for the dashboard exec-PTY into platform-admin.
WARROOM2_DOCKER_SOCK=/var/run/docker.sock
DOCKER_HOST=unix:///var/run/docker.sock
